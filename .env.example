# ===========================================
# NETWORK
# ===========================================
PB_HOST=0.0.0.0
PB_PORT=8090

# ===========================================
# META
# ===========================================
PB_APP_NAME=My PocketBase App
PB_APP_URL=http://localhost:8090
PB_SENDER_NAME=Support
PB_SENDER_ADDRESS=noreply@localhost
PB_HIDE_CONTROLS=false

# ===========================================
# SECURITY
# ===========================================
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=MyStr0ngAndL0ngPa$$w0rd
PB_DEBUG=false
# Generate with: openssl rand -base64 32
PB_ENCRYPTION_KEY=

# ===========================================
# SMTP
# ===========================================
PB_SMTP_ENABLED=false
PB_SMTP_HOST=
PB_SMTP_PORT=587
PB_SMTP_USERNAME=
PB_SMTP_PASSWORD=
PB_SMTP_AUTH_METHOD=PLAIN
PB_SMTP_TLS=true
PB_SMTP_LOCAL_NAME=

# ===========================================
# S3 STORAGE
# ===========================================
PB_S3_ENABLED=false
PB_S3_BUCKET=
PB_S3_REGION=
PB_S3_ENDPOINT=
PB_S3_ACCESS_KEY=
PB_S3_SECRET=
PB_S3_FORCE_PATH_STYLE=false

# ===========================================
# BACKUPS
# ===========================================
PB_BACKUPS_CRON=0 0 * * *
PB_BACKUPS_CRON_MAX_KEEP=3
PB_BACKUPS_S3_ENABLED=false
PB_BACKUPS_S3_BUCKET=
PB_BACKUPS_S3_REGION=
PB_BACKUPS_S3_ENDPOINT=
PB_BACKUPS_S3_ACCESS_KEY=
PB_BACKUPS_S3_SECRET=
PB_BACKUPS_S3_FORCE_PATH_STYLE=false

# ===========================================
# LOGS
# ===========================================
PB_LOGS_MAX_DAYS=7
PB_LOGS_MIN_LEVEL=0
PB_LOGS_LOG_IP=true
PB_LOGS_LOG_AUTH_ID=true

# ===========================================
# RATE LIMITING
# Format: label|audience|duration|maxRequests (semicolon-separated)
# Example: *:auth||3|2;*:create||5|20;/api/batch||1|3;/api/||10|300
# ===========================================
PB_RATE_LIMITS_ENABLED=false
PB_RATE_LIMITS_RULES=

# ===========================================
# TRUSTED PROXY
# Comma-separated headers: X-Real-IP,X-Forwarded-For
# ===========================================
PB_TRUSTED_PROXY_HEADERS=
PB_TRUSTED_PROXY_USE_LEFTMOST_IP=false

# ===========================================
# BATCH REQUESTS
# ===========================================
PB_BATCH_ENABLED=true
PB_BATCH_MAX_REQUESTS=100
PB_BATCH_TIMEOUT=120

# ===========================================
# EMAIL TEMPLATES
# Path to custom HTML template files (optional)
# Mount your templates via volume: ./pb_templates:/pb_templates
# See docs/templates.md for available variables and spam score tips
# ===========================================
PB_TPL_VERIFICATION_SUBJECT=
PB_TPL_VERIFICATION_BODY=
PB_TPL_RESET_PWD_SUBJECT=
PB_TPL_RESET_PWD_BODY=
PB_TPL_CONFIRM_EMAIL_SUBJECT=
PB_TPL_CONFIRM_EMAIL_BODY=
PB_TPL_OTP_SUBJECT=
PB_TPL_OTP_BODY=